# Canonicalize host: force HTTPS and strip "www" in a single redirect,
# so http://, https://www., and http://www. all collapse to the one
# canonical origin used in <link rel="canonical"> across the site.
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Serve index.html for directory requests (clean URLs like /about/)
DirectoryIndex index.html

# Collapse explicit /index.html requests to the clean directory URL
# e.g. /about/index.html -> /about/
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^(.*?)index\.html$ /$1 [R=301,L]

# Redirect old /pages/*.html URLs to the new clean URLs.
# e.g. /pages/about.html -> /about/
#      /pages/breakdowns/lead-flow-automation.html -> /breakdowns/lead-flow-automation/
#      /pages/breakdowns.html -> /breakdowns/
RedirectMatch 301 ^/pages/(.*)\.html$ /$1/

# Block access to non-public source/dev files in case they ever end up
# in the deployed web root (Supabase functions, editor/tool configs, docs)
RedirectMatch 404 ^/backend(/|$)
RedirectMatch 404 ^/\.git(/|$)
RedirectMatch 404 ^/\.claude(/|$)
RedirectMatch 404 ^/\.vscode(/|$)
RedirectMatch 404 ^/.*\.md$
