# Canonicalize host: force HTTPS and strip "www" in a single redirect,
# so http://, https://www., and http://www. all collapse to the one
# canonical origin used in <link rel="canonical"> across the site.
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Serve index.html for directory requests (clean URLs like /about/)
DirectoryIndex index.html

# Custom branded 404 page, excluded from indexing via its own meta robots tag
ErrorDocument 404 /404.html

# Collapse explicit /index.html requests to the clean directory URL
# e.g. /about/index.html -> /about/
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^(.*?)index\.html$ /$1 [R=301,L]

# Redirect old /pages/*.html URLs to the new clean URLs.
# e.g. /pages/about.html -> /about/
#      /pages/breakdowns/lead-flow-automation.html -> /breakdowns/lead-flow-automation/
#      /pages/breakdowns.html -> /breakdowns/
RedirectMatch 301 ^/pages/(.*)\.html$ /$1/

# Block access to non-public source/dev files in case they ever end up
# in the deployed web root (Supabase functions, editor/tool configs, docs)
RedirectMatch 404 ^/backend(/|$)
RedirectMatch 404 ^/\.git(/|$)
RedirectMatch 404 ^/\.claude(/|$)
RedirectMatch 404 ^/\.vscode(/|$)
RedirectMatch 404 ^/.*\.md$

# Compress text-based assets to speed up page loads (Core Web Vitals)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Set far-future cache lifetimes for static assets, short lifetimes for HTML
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
